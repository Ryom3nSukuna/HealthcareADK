{
    "name": "Hospital Patient Flow Theme",
    "dataColors": [
        "#1B3B5F", 
        "#3498DB", 
        "#7F8C8D", 
        "#2C3E50", 
        "#27AE60", 
        "#BDC3C7", 
        "#2980B9", 
        "#16A085"
    ],
    "background": "#F2F4F5",
    "foreground": "#2C3E50",
    "tableAccent": "#1B3B5F",
    "visualStyles": {
        "*": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#BDC3C7" } },
                        "transparency": 50
                    }
                ],
                "border": [
                    {
                        "show": false
                    }
                ],
                "title": [
                    {
                        "show": true,
                        "fontFamily": "Segoe UI Semibold",
                        "fontSize": 12,
                        "color": { "solid": { "color": "#2C3E50" } }
                    }
                ],
                "labels": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#2C3E50" } }
                    }
                ]
            }
        },
        "page": {
            "*": {
                "background": [
                    {
                        "color": { "solid": { "color": "#FFFFFF" } },
                        "transparency": 0
                    }
                ]
            }
        },
        "card": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#FFFFFF" } },
                        "transparency": 0
                    }
                ],
                "labels": [
                    {
                        "color": { "solid": { "color": "#2C3E50" } },
                        "fontSize": 28,
                        "fontFamily": "Segoe UI Bold"
                    }
                ],
                "categoryLabels": [
                    {
                        "color": { "solid": { "color": "#7F8C8D" } },
                        "fontSize": 10
                    }
                ]
            }
        },
        "donutChart": {
            "*": {
                "legend": [
                    {
                        "show": true,
                        "position": "Right",
                        "labelColor": { "solid": { "color": "#2C3E50" } }
                    }
                ]
            }
        },
        "areaChart": {
            "*": {
                "plotArea": [
                    {
                        "transparency": 40
                    }
                ]
            }
        }
    }
}